{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "moduleResolution": "node",
    "outDir": "./dist",          
    "rootDirs": ["./src", "../packages/schemas/src"],           
    "sourceMap": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,          
    "allowSyntheticDefaultImports": true, 
    "skipLibCheck": true,              
    "baseUrl": "./",
    "paths": {
      "@health/schemas": ["../packages/schemas/src/index.ts"],
      "@health/schemas/*": ["../packages/schemas/src/*"]
    }
  }
}


  
   