datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  DOCTOR
  PATIENT
}




enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
  PENDING
  COUNTER_OFFER
  REJECTED
  RESCHEDULE_REQUIRED  // Add this line
}

enum AppointmentType {
  ONLINE
  OFFLINE
}

enum DoctorVerificationStatus {
  PENDING_DOCUMENTS
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
}

// Users 
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  notifications Notification[] 

  doctor       Doctor?
  patient      Patient?

  @@index([email])
}

// Doctor
model Doctor {
  id                 String                   @id @default(cuid())
  userId             String                   @unique
  user               User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name               String
  specialty          String
  bio                String?
  avatarUrl          String?
  consultationFee    Int?                      
  verificationStatus DoctorVerificationStatus @default(PENDING_DOCUMENTS)

  licenseDocUrl      String?
  degreeDocUrl       String?

  
  appointments       Appointment[]
  ratings            Rating[]
  doctorAvailability DoctorAvailability[]
  createdAt          DateTime @default(now())

  @@index([specialty])
  @@index([verificationStatus])
}

// Patient 
model Patient {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                String
  dateOfBirth         DateTime?
  allergies           String[]
  currentMedications  String[]
  bloodGroup          String?
  emergencyContact    String?

  appointments        Appointment[]
  ehrDocuments        EhrDocument[]

  createdAt           DateTime @default(now())
}



// Appointment 
model Appointment {
  id              String            @id @default(cuid())
  doctorId        String
  doctor          Doctor            @relation(fields: [doctorId], references: [id])
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id])

  scheduledAt     DateTime
  durationMinutes Int               @default(30)
  type            AppointmentType
  status          AppointmentStatus @default(PENDING)

  // New fields for counter offer
  originalScheduledAt DateTime?
  proposedAt         DateTime?
  counterOfferAt     DateTime?

  queueNumber     Int?
  videoLink       String?
  notes           String?

  chatRoom        ChatRoom?
  payment         Payment?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([doctorId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([patientId, scheduledAt])
  @@index([status])
}

// Chat
model ChatRoom {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
  closesAt      DateTime
  messages      ChatMessage[]
  createdAt     DateTime    @default(now())
}

model ChatMessage {
  id         String   @id @default(cuid())
  roomId     String
  room       ChatRoom @relation(fields: [roomId], references: [id])
  senderRole Role
  senderId   String
  fileUrl    String?
  content    String
  createdAt  DateTime @default(now())

  @@index([roomId, createdAt])
}

// EHR Documents 
model EhrDocument {
  id          String   @id @default(cuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id])
  fileUrl     String
  fileName    String
  mimeType    String
  uploadedAt  DateTime @default(now())

  @@index([patientId])
}

// Ratings 
model Rating {
  id            String   @id @default(cuid())
  doctorId      String
  doctor        Doctor   @relation(fields: [doctorId], references: [id])
  patientId     String
  appointmentId String   @unique
  score         Int      
  comment       String?
  createdAt     DateTime @default(now())

  @@index([doctorId])
}

// Payment
model Payment {
  id              String        @id @default(cuid())
  appointmentId   String        @unique
  appointment     Appointment   @relation(fields: [appointmentId], references: [id])
  orderId         String?       @unique
  paymentId       String?
  amount          Int
  currency        String        @default("INR")
  provider        String  
  providerOrderId String?
  providerPaymentId String?
  status          String        @default("pending")
  createdAt       DateTime      @default(now())
}


// Add after Payment model
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  isRead    Boolean  @default(false)
  metadata  Json?    // For additional data like appointmentId, doctorId, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
}

// Doctor Availability Slots
model DoctorAvailability {
  id          String   @id @default(cuid())
  doctorId    String
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date        DateTime // Specific date (YYYY-MM-DD)
  startTime   String   // Format: "09:00"
  endTime     String   // Format: "09:30"
  isAvailable Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([doctorId, date, startTime])
  @@index([doctorId, date])
  @@index([doctorId, isAvailable])
}
enum NotificationType {
  APPOINTMENT_CONFIRMED
  APPOINTMENT_CANCELLED
  APPOINTMENT_REMINDER
  APPOINTMENT_RESCHEDULED
  MESSAGE_RECEIVED
  RATING_REQUEST
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  DOCTOR_RESPONSE
  SYSTEM_ALERT
}